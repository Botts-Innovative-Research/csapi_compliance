{
  "name": "csapi-compliance-assessor",
  "version": "1.0.0",
  "description": "OGC API - Connected Systems compliance assessment tool",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "build": "next build && tsc --project tsconfig.server.json",
    "prebuild": "npm run fetch-schemas",
    "start": "node dist/server/index.js",
    "fetch-schemas": "tsx scripts/fetch-schemas.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:all-browsers": "playwright test --project=chromium --project=firefox --project=webkit",
    "perf": "tsx scripts/perf-benchmark.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "express": "^4.21.0",
    "ipaddr.js": "^2.2.0",
    "next": "^14.2.0",
    "p-limit": "^6.1.0",
    "pdfkit": "^0.15.0",
    "pino": "^9.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "undici": "^6.19.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.45.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.4",
    "pino-pretty": "^11.0.0",
    "playwright": "^1.45.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
